# Required for live AI responses. Without it, the app falls back to a deterministic mock.
GOOGLE_API_KEY=

# Optional. Defaults to gemini-2.5-flash (matches the notebook).
GEMINI_MODEL=gemini-2.5-flash

# Optional. Point to an external retrieval service (e.g., a Python service that wraps the
# notebook's Chroma + LangGraph pipeline). If unset, the app uses an in-memory keyword retriever
# over src/data/resources.json.
RETRIEVAL_ENDPOINT=
